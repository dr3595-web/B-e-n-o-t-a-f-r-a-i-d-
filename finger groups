#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

Adafruit_PWMServoDriver pwm1 = Adafruit_PWMServoDriver(0x40);
Adafruit_PWMServoDriver pwm2 = Adafruit_PWMServoDriver(0x41);

#define SERVOMIN  150
#define SERVOMAX  600
#define SERVO_FREQ 50

int pinkies[] = {6, 12, 3, 17, 19};
int rings[]   = {16, 11, 2, 25, 9};
int middles[] = {13, 7, 1, 26, 18};
int pointers[]= {14, 5, 8, 31, 21};
int thumbs[]  = {15, 32, 4, 24, 20};

void setup() {
  Serial.begin(115200);

  pwm1.begin();
  pwm1.setOscillatorFrequency(27000000);
  pwm1.setPWMFreq(SERVO_FREQ);

  pwm2.begin();
  pwm2.setOscillatorFrequency(27000000);
  pwm2.setPWMFreq(SERVO_FREQ);

  delay(1000);

  Serial.println("Starting sequence...");
}

void sweepServo(int servoInput) {

  Adafruit_PWMServoDriver* pwm;
  uint8_t channel;

  if (servoInput <= 16) {
    pwm = &pwm1;
    channel = servoInput - 1;
  } else {
    pwm = &pwm2;
    channel = servoInput - 17;
  }

  Serial.print("Servo Input ");
  Serial.println(servoInput);

  for (uint16_t pulselen = SERVOMIN; pulselen < SERVOMAX; pulselen++) {
    pwm->setPWM(channel, 0, pulselen);
    delay(3);
  }

  delay(250);

  for (uint16_t pulselen = SERVOMAX; pulselen > SERVOMIN; pulselen--) {
    pwm->setPWM(channel, 0, pulselen);
    delay(3);
  }

  delay(400);
}

void moveFingerGroup(int group[], int size, const char* name) {

  Serial.print("Moving ");
  Serial.println(name);

  for (int i = 0; i < size; i++) {

    Serial.print("Hand ");
    Serial.println(i + 1);

    sweepServo(group[i]);
  }

  delay(1000);
}

void loop() {

  moveFingerGroup(pinkies, 5, "Pinkies");
  moveFingerGroup(rings, 5, "Rings");
  moveFingerGroup(middles, 5, "Middles");
  moveFingerGroup(pointers, 5, "Pointers");
  moveFingerGroup(thumbs, 5, "Thumbs");

  delay(3000);
}
