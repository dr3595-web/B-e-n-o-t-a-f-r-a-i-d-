#include <MIDIUSB.h>
#include <MIDIUSB_Defs.h>
#include <frequencyToNote.h>
#include <pitchToFrequency.h>
#include <pitchToNote.h>
#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

Adafruit_PWMServoDriver pwm1 = Adafruit_PWMServoDriver(0x40);
Adafruit_PWMServoDriver pwm2 = Adafruit_PWMServoDriver(0x41);

#define SERVOMIN   150
#define SERVOMAX   600
#define SERVO_FREQ  50

uint8_t arm_seg1[] = {12, 15,  5, 13, 14};
uint8_t arm_seg2[] = { 6, 10, 11,  4, 31};
uint8_t arm_seg3[] = { 0,  1,  2,  7,  3};
uint8_t arm_seg4[] = {25, 24, 16, 30, 23};
uint8_t arm_seg5[] = {17,  8, 18, 20, 19};

uint8_t wrist[]    = {28, 27, 30, 29};

#define SEG_SIZE   5
#define WRIST_SIZE 4

#define FINGER_MIDDLE  0
#define FINGER_RING    1
#define FINGER_PINKY   2
#define FINGER_POINTER 3
#define FINGER_THUMB   4

const int S0 = A2;
const int S1 = A3;
const int S2 = A6;
const int S3 = A7;
const int SIG = A0;

int buf8[3]  = {680, 680, 680};
int buf10[3] = {705, 705, 705};
int buf11[3] = {690, 690, 690};
int buf12[3] = {680, 680, 680};
int buf14[3] = {695, 695, 695};
int bufIdx = 0;

float base8  = 680;
float base10 = 705;
float base11 = 690;
float base12 = 680;
float base14 = 695;

bool isFlexxing8  = false;
bool isFlexxing10 = false;
bool isFlexxing11 = false;
bool isFlexxing12 = false;
bool isFlexxing14 = false;

int conseq8  = 0;
int conseq10 = 0;
int conseq11 = 0;
int conseq12 = 0;
int conseq14 = 0;

#define CONSEQ_THRESHOLD 4

int flexValues[16];

unsigned long lastWristSpin = 0;
#define WRIST_SPIN_INTERVAL 30000UL

void selectChannel(int ch) {
  digitalWrite(S0, (ch & 1) ? HIGH : LOW);
  digitalWrite(S1, (ch & 2) ? HIGH : LOW);
  digitalWrite(S2, (ch & 4) ? HIGH : LOW);
  digitalWrite(S3, (ch & 8) ? HIGH : LOW);
}

void readAllChannels() {
  selectChannel(0);  delayMicroseconds(500); flexValues[0]  = analogRead(SIG);
  selectChannel(2);  delayMicroseconds(500); flexValues[2]  = analogRead(SIG);
  selectChannel(4);  delayMicroseconds(500); flexValues[4]  = analogRead(SIG);
  selectChannel(6);  delayMicroseconds(500); flexValues[6]  = analogRead(SIG);
  selectChannel(7);  delayMicroseconds(500); flexValues[7]  = analogRead(SIG);
  selectChannel(8);  delayMicroseconds(500); flexValues[8]  = analogRead(SIG);
  selectChannel(10); delayMicroseconds(500); flexValues[10] = analogRead(SIG);
  selectChannel(11); delayMicroseconds(500); flexValues[11] = analogRead(SIG);
  selectChannel(12); delayMicroseconds(500); flexValues[12] = analogRead(SIG);
  selectChannel(13); delayMicroseconds(500); flexValues[13] = analogRead(SIG);
  selectChannel(14); delayMicroseconds(500); flexValues[14] = analogRead(SIG);
}

int avg3(int* buf) { return (buf[0] + buf[1] + buf[2]) / 3; }

void setServo(uint8_t servoIndex, uint16_t pulselen) {
  if (servoIndex >= 32) return;
  Adafruit_PWMServoDriver &pwm = (servoIndex < 16) ? pwm1 : pwm2;
  uint8_t channel = (servoIndex < 16) ? servoIndex : servoIndex - 16;
  pwm.setPWM(channel, 0, pulselen);
}

void moveFingerAllSegments(uint8_t fingerSlot, uint16_t pulselen) {
  setServo(arm_seg1[fingerSlot], pulselen);
  setServo(arm_seg2[fingerSlot], pulselen);
  setServo(arm_seg3[fingerSlot], pulselen);
  setServo(arm_seg4[fingerSlot], pulselen);
  setServo(arm_seg5[fingerSlot], pulselen);
}

void curleFingerAllSegments(uint8_t fingerSlot, const char* label) {
  Serial.print("Flexed: "); Serial.println(label);
  for (uint16_t p = SERVOMIN; p <= SERVOMAX; p += 5) {
    moveFingerAllSegments(fingerSlot, p);
    delay(2);
  }
  delay(200);
  for (uint16_t p = SERVOMAX; p >= SERVOMIN; p -= 5) {
    moveFingerAllSegments(fingerSlot, p);
    delay(2);
  }
}

void spinWrists() {
  Serial.println("Wrist spin");
  for (uint16_t p = SERVOMIN; p <= SERVOMAX; p += 5) {
    setServo(28, p);
    setServo(27, p);
    setServo(29, p);
    setServo(30, p);
    delay(2);
  }
  delay(200);
  for (uint16_t p = SERVOMAX; p >= SERVOMIN; p -= 5) {
    setServo(28, p);
    setServo(27, p);
    setServo(29, p);
    setServo(30, p);
    delay(2);
  }
}

void controlChange(byte channel, byte control, byte value) {
  midiEventPacket_t event = {0x0B, 0xB0 | channel, control, value};
  MidiUSB.sendMIDI(event);
}

void setup() {
  pinMode(S0, OUTPUT);
  pinMode(S1, OUTPUT);
  pinMode(S2, OUTPUT);
  pinMode(S3, OUTPUT);
  digitalWrite(S0, LOW);
  digitalWrite(S1, LOW);
  digitalWrite(S2, LOW);
  digitalWrite(S3, LOW);

  Serial.begin(115200);
  delay(2000);

  pwm1.begin();
  pwm1.setOscillatorFrequency(27000000);
  pwm1.setPWMFreq(SERVO_FREQ);

  pwm2.begin();
  pwm2.setOscillatorFrequency(27000000);
  pwm2.setPWMFreq(SERVO_FREQ);

  lastWristSpin = millis();
  Serial.println("Ready.");
}

void loop() {
  readAllChannels();

  buf8[bufIdx]  = flexValues[8];
  buf10[bufIdx] = flexValues[10];
  buf11[bufIdx] = flexValues[11];
  buf12[bufIdx] = flexValues[12];
  buf14[bufIdx] = flexValues[14];
  bufIdx = (bufIdx + 1) % 3;

  int avg8  = avg3(buf8);
  int avg10 = avg3(buf10);
  int avg11 = avg3(buf11);
  int avg12 = avg3(buf12);
  int avg14 = avg3(buf14);

  if (!isFlexxing8) base8 = base8 * 0.995 + avg8 * 0.005;
  bool flexed8 = (base8 - avg8) > 237;
  if (flexed8) {
    if (!isFlexxing8) {
      conseq8++;
      if (conseq8 >= CONSEQ_THRESHOLD) {
        curleFingerAllSegments(FINGER_THUMB, "left thumb");
        isFlexxing8 = true;
        conseq8 = 0;
      }
    }
  } else {
    conseq8 = 0;
    isFlexxing8 = false;
  }

  if (!isFlexxing10) base10 = base10 * 0.995 + avg10 * 0.005;
  bool flexed10 = (base10 - avg10) > 620;
  if (flexed10) {
    if (!isFlexxing10) {
      conseq10++;
      if (conseq10 >= CONSEQ_THRESHOLD) {
        curleFingerAllSegments(FINGER_MIDDLE, "left middle");
        isFlexxing10 = true;
        conseq10 = 0;
      }
    }
  } else {
    conseq10 = 0;
    isFlexxing10 = false;
  }

  if (!isFlexxing11) base11 = base11 * 0.95 + avg11 * 0.05;
  bool flexed11 = (base11 - avg11) > 3;
  if (flexed11) {
    if (!isFlexxing11) {
      conseq11++;
      if (conseq11 >= CONSEQ_THRESHOLD) {
        curleFingerAllSegments(FINGER_PINKY, "left pinky");
        curleFingerAllSegments(FINGER_POINTER, "left pointer (pinky-triggered)");
        curleFingerAllSegments(FINGER_MIDDLE, "left middle (pinky-triggered)");
        isFlexxing11 = true;
        conseq11 = 0;
      }
    }
  } else {
    conseq11 = 0;
    isFlexxing11 = false;
  }

  if (!isFlexxing12) base12 = base12 * 0.95 + avg12 * 0.05;
  bool flexed12 = (base12 - avg12) > 9;
  if (flexed12) {
    if (!isFlexxing12) {
      conseq12++;
      if (conseq12 >= CONSEQ_THRESHOLD) {
        curleFingerAllSegments(FINGER_POINTER, "left pointer");
        isFlexxing12 = true;
        conseq12 = 0;
      }
    }
  } else {
    conseq12 = 0;
    isFlexxing12 = false;
  }

  if (!isFlexxing14) base14 = base14 * 0.95 + avg14 * 0.05;
  bool flexed14 = (base14 - avg14) > 12;
  if (flexed14) {
    if (!isFlexxing14) {
      conseq14++;
      if (conseq14 >= CONSEQ_THRESHOLD) {
        curleFingerAllSegments(FINGER_RING, "left ring");
        curleFingerAllSegments(FINGER_THUMB, "left ring + thumb");
        isFlexxing14 = true;
        conseq14 = 0;
      }
    }
  } else {
    conseq14 = 0;
    isFlexxing14 = false;
  }

  if (millis() - lastWristSpin >= WRIST_SPIN_INTERVAL) {
    spinWrists();
    lastWristSpin = millis();
  }
}
